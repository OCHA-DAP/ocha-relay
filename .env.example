# Base URL of the Listmonk instance, including the /api suffix.
# Example: https://listmonk.example.org/api
DSCI_LISTMONK_BASE_URL=

# Listmonk API credentials. Create an API user in Listmonk admin →
# Settings → Users, grant campaigns:manage + campaigns:get permissions.
DSCI_LISTMONK_API_USERNAME=
DSCI_LISTMONK_API_KEY=
